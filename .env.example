# AI / Search services
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=your_pinecone_index
PINECONE_NAMESPACE=products
PINECONE_EMBED_MODEL=multilingual-e5-large
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBED_MODEL=text-embedding-3-small

# OAuth
GOOGLE_OAUTH_ENABLED=0
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Database (used by application/config/database.php)
DB_HOST=localhost
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DATABASE=shop

# SMTP (used by application/config/mailer.php)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_SMTP_AUTH=1
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_EMAIL=no-reply@your-domain.com
MAIL_FROM_NAME=HutechWebShop

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Docker (.NET app + SQL Server)
MSSQL_SA_PASSWORD=Your_Strong_Passw0rd!
ConnectionStrings__DefaultConnection=Server=sqlserver_hutech;Database=hutechiteventDB;User Id=sa;Password=Your_Strong_Passw0rd!;TrustServerCertificate=True
ASPNETCORE_URLS=http://+:8080
